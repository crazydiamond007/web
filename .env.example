# Copy to `.env` and fill in. Never commit `.env`.
# Every value here maps 1:1 onto a field of `webhook_receiver.config.Settings`
# (SPEC §NFR-11: no magic numbers in the code).

# --- Runtime -----------------------------------------------------------------
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Database ----------------------------------------------------------------
# Must be the asyncpg driver: the app and the worker are both async.
#
# The PORT here is the single source of truth: the Makefile publishes the Compose
# Postgres on it, and it is the port your SQL client should use (`make db-url`).
#
# Change it if something already owns 5432 -- a natively installed Postgres is
# common on WSL and Homebrew. That clash does NOT announce itself: Docker still
# reports the port as published, the connection still succeeds, and it lands on
# the other server, which replies "password authentication failed for user
# webhook". It looks exactly like a credentials bug and is not one. 5433 is a
# fine second choice.
DATABASE_URL=postgresql+asyncpg://webhook:webhook@localhost:5432/webhook_receiver
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# --- Ingestion / signature verification (FR-3, FR-4) --------------------------
# Per-source HMAC-SHA256 signing keys, as a JSON object. The key is the {source}
# path segment of POST /v1/webhooks/{source}. A source absent from this map is
# rejected with the same 401 as a bad signature.
WEBHOOK_SECRETS={"stripe":"whsec_replace_me","github":"ghs_replace_me"}

# FR-4: reject a signed timestamp further than this from now, in either
# direction, so a captured request cannot be replayed later.
SIGNATURE_TIMESTAMP_TOLERANCE_SECONDS=300

# Reject bodies larger than this before spending CPU on the HMAC.
MAX_PAYLOAD_BYTES=1048576

# --- Admin API (FR-20) -------------------------------------------------------
# Required by the admin, replay, and DLQ endpoints. Ingestion authenticates by
# signature only and ignores this.
ADMIN_API_KEY=replace_me_with_a_long_random_string

# FR-18: default rows per admin listing (a caller may ask for fewer, or more up
# to the hard ceiling in the route).
ADMIN_PAGE_SIZE=50

# FR-16: the most events one replay request may touch. A bound, not a preference.
# Replay is synchronous and takes an advisory lock per event, so an unbounded
# "replay everything" is a self-inflicted outage wearing a recovery's clothes.
# Page through it: the DLQ selector drains oldest-first, so repeating the call
# makes progress.
REPLAY_MAX_BATCH=100

# --- Worker poll (FR-7, FR-9) ------------------------------------------------
# Rows claimed per `SELECT ... FOR UPDATE SKIP LOCKED` batch.
POLL_BATCH_SIZE=100
# Sleep between polls when the last batch came back empty.
POLL_INTERVAL_SECONDS=1.0
# FR-9: how long a worker waits on `pg_advisory_xact_lock` before giving up and
# letting the event be retried. Bounds the damage from a stuck transaction.
ADVISORY_LOCK_TIMEOUT_SECONDS=5.0

# --- Retry and backoff (FR-12, FR-13) ----------------------------------------
# FR-13: attempts are bounded; on reaching this count the event is dead-lettered.
MAX_ATTEMPTS=5
# FR-12: delay = min(cap, base * 2**attempt), then full jitter: random(0, delay).
BACKOFF_BASE_SECONDS=1.0
BACKOFF_CAP_SECONDS=300.0
# SPEC §6.4: set to an integer to make the jitter RNG deterministic. Leave unset
# in production -- deterministic jitter would re-synchronise a failing batch,
# which is the exact thundering herd jitter exists to prevent.
# JITTER_SEED=
